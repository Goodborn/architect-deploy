#!/usr/bin/env python3
"""Architect Deploy — Entry point script."""

import sys
import os

# Determine base directory for import resolution
_script_dir = os.path.dirname(os.path.realpath(__file__))

# git clone https://github.com/goodborn/architect-deploy.git && \
# cd architect-deploy && \
# make run

# When running from source: ./bin/architect-deploy → libs at ../
# Possible library locations
_paths = [
    os.path.join(os.path.dirname(_script_dir), "lib", "architect-deploy"), # /usr/lib/architect-deploy
    os.path.dirname(_script_dir), # local ./bin/
    _script_dir # local root ./
]

for path in _paths:
    if os.path.isdir(os.path.join(path, "architect_deploy")):
        sys.path.insert(0, path)
        break

from architect_deploy.main import main

if __name__ == "__main__":
    sys.exit(main())
