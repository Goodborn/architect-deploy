#!/usr/bin/env python3
"""CKDEPS — Entry point script."""

import sys
import os

# Determine base directory for import resolution
_script_dir = os.path.dirname(os.path.realpath(__file__))

# git clone https://github.com/goodborn/ckdeps.git && \
# cd ckdeps && \
# make run

# When running from source: ./bin/ckdeps → libs at ../
# Possible library locations
_paths = [
    os.path.join(os.path.dirname(_script_dir), "lib", "ckdeps"), # /usr/lib/ckdeps
    os.path.dirname(_script_dir), # local ./bin/
    _script_dir # local root ./
]

for path in _paths:
    if os.path.isdir(os.path.join(path, "ckdeps")):
        sys.path.insert(0, path)
        break

from ckdeps.main import main

if __name__ == "__main__":
    sys.exit(main())
